# CrewTUI API Keys
# Copy this file to your project work directory as .env
# Only fill in the keys for providers you plan to use.

# xAI (Grok models)
XAI_API_KEY=

# NVIDIA (Kimi and other NVIDIA-hosted models)
NVIDIA_API_KEY=

# OpenRouter (access to many models via one key)
OPENROUTER_API_KEY=

# Tavily (AI-optimized web search)
TAVILY_API_KEY=
