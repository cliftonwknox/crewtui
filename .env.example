# Starling API Keys
# Copy this file to your project work directory as .env
# Only fill in the keys for providers you plan to use.

# OpenAI (GPT-4o, o1)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet, Haiku, Opus)
ANTHROPIC_API_KEY=

# OpenRouter (one key for Claude, GPT, Llama, and many more)
OPENROUTER_API_KEY=

# xAI (Grok models)
XAI_API_KEY=

# DeepSeek (V3, R1 Reasoning)
DEEPSEEK_API_KEY=

# Mistral (Mistral Large)
MISTRAL_API_KEY=

# Groq (fast Llama inference)
GROQ_API_KEY=

# Together (Llama, Mixtral, and more)
TOGETHER_API_KEY=

# NVIDIA (Kimi and other NVIDIA-hosted models)
NVIDIA_API_KEY=

# Alibaba (Qwen Plus models)
ALIBABA_API_KEY=

# Google (Gemini models)
GOOGLE_API_KEY=

# Tavily (AI-optimized web search tool)
TAVILY_API_KEY=
